# Copy to .env to override defaults. All are optional — the app runs without it.

# Set to "false" to call a real backend instead of the in-memory mock.
VITE_USE_MOCK_API=true

# Base URL all API requests are prefixed with.
VITE_API_BASE_URL=/api

# development | staging | production
VITE_APP_ENV=development

# Networking / behavior tuning
VITE_REQUEST_TIMEOUT_MS=15000
VITE_MAX_RETRIES=2
VITE_CACHE_TTL_MS=60000
